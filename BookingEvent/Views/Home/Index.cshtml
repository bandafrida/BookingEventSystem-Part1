@{
    ViewData["Title"] = "Dashboard";
}

<div class="hero">

    <h1 class="fw-bold">Welcome to Event Booking System</h1>
    <p class="text-muted">Manage events, venues, and bookings easily.</p>

</div>

<div class="row">

    <div class="col-md-4 mb-4">
        <div class="card card-custom p-3 text-center">
            <h4>📅 Events</h4>
            <p>Manage all events</p>
            <a asp-controller="Event" asp-action="Index" class="btn btn-primary">Open</a>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card card-custom p-3 text-center">
            <h4>🏟 Venues</h4>
            <p>Manage venues</p>
            <a asp-controller="Venue" asp-action="Index" class="btn btn-success">Open</a>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card card-custom p-3 text-center">
            <h4>📌 Bookings</h4>
            <p>Manage bookings</p>
            <a asp-controller="Booking" asp-action="Index" class="btn btn-warning">Open</a>
        </div>
    </div>

</div>