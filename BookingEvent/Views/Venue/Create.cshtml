@model BookingEvent.Models.Venue

@{
    ViewData["Title"] = "Create Venue";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white">
                    <h3>Create Venue</h3>
                </div>

                <div class="card-body">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <!-- Venue Name -->
                        <div class="mb-3">
                            <label asp-for="VenueName" class="form-label"></label>
                            <input asp-for="VenueName" class="form-control" />
                            <span asp-validation-for="VenueName" class="text-danger"></span>
                        </div>

                        <!-- Location -->
                        <div class="mb-3">
                            <label asp-for="VenueLocation" class="form-label"></label>
                            <input asp-for="VenueLocation" class="form-control" />
                            <span asp-validation-for="VenueLocation" class="text-danger"></span>
                        </div>

                        <!-- Capacity -->
                        <div class="mb-3">
                            <label asp-for="VenueCapacity" class="form-label"></label>
                            <input asp-for="VenueCapacity" class="form-control" />
                            <span asp-validation-for="VenueCapacity" class="text-danger"></span>
                        </div>

                        <!-- Image -->
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label"></label>
                            <input asp-for="ImageUrl" class="form-control" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            Create Venue
                        </button>

                        <a asp-action="Index" class="btn btn-secondary w-100 mt-2">
                            Back
                        </a>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>