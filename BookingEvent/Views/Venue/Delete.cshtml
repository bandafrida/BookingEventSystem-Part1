@model BookingEvent.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-danger text-white">
            <h3>Delete Venue</h3>
        </div>

        <div class="card-body">

            <h4>Are you sure you want to delete this venue?</h4>

            <hr />

            <img src="@Model.ImageUrl"
                 class="img-fluid mb-3"
                 style="height:300px; width:100%; object-fit:cover;" />

            <p><strong>Name:</strong> @Model.VenueName</p>
            <p><strong>Location:</strong> @Model.VenueLocation</p>
            <p><strong>Capacity:</strong> @Model.VenueCapacity</p>

        </div>

        <div class="card-footer d-flex gap-2">

            <form asp-action="Delete">
                <input type="hidden" asp-for="VenueId" />

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </form>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </div>

</div>