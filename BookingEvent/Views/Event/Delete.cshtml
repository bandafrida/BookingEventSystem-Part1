@model BookingEvent.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-danger text-white">
            <h3>Delete Event</h3>
        </div>

        <div class="card-body">

            <h4>Are you sure you want to delete this event?</h4>

            <hr />

            <img src="@Model.ImageUrl"
                 class="img-fluid mb-3"
                 style="height:300px; width:100%; object-fit:cover;" />

            <p><strong>Name:</strong> @Model.EventName</p>

            <p><strong>Date:</strong> @Model.EventDate.ToString("dd MMM yyyy")</p>

            <p><strong>Time:</strong> @Model.EventTime.ToString("HH:mm")</p>

        </div>

        <div class="card-footer d-flex gap-2">

            <form asp-action="Delete">
                <input type="hidden" asp-for="EventId" />

                <button type="submit" class="btn btn-danger">
                    Delete
                </button>
            </form>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </div>

    </div>

</div>