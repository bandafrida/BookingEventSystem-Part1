@model BookingEvent.Models.Event

@{
    ViewData["Title"] = "Create Event";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white">
                    <h3>Create Event</h3>
                </div>

                <div class="card-body">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger">
                        </div>

                        <!-- Event Name -->
                        <div class="mb-3">
                            <label asp-for="EventName"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="EventName"
                                   class="form-control" />

                            <span asp-validation-for="EventName"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- Event Date -->
                        <div class="mb-3">
                            <label asp-for="EventDate"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="EventDate"
                                   type="date"
                                   class="form-control" />

                            <span asp-validation-for="EventDate"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- Event Time -->
                        <div class="mb-3">
                            <label asp-for="EventTime"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="EventTime"
                                   type="time"
                                   class="form-control" />

                            <span asp-validation-for="EventTime"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- Image URL -->
                        <div class="mb-3">
                            <label asp-for="ImageUrl"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="ImageUrl"
                                   class="form-control" />

                            <span asp-validation-for="ImageUrl"
                                  class="text-danger">
                            </span>
                        </div>

                        <!-- Button -->
                        <div class="d-flex gap-2">

                            <button type="submit"
                                    class="btn btn-success w-100">
                                Create Event
                            </button>

                            <a asp-action="Index"
                                   class="btn btn-secondary w-100">
                                Back
                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}